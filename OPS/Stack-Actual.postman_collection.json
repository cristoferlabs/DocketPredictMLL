    {
      "name": "🤖 Telegram Bot API (directo — funciona en modo poll)",
      "description": "Llamadas directas a api.telegram.org/bot<token>. Funcionan SIEMPRE, independientemente del modo de ingesta.\n\n✅ Estas requests sirven para:\n  • Verificar que el token es válido (getMe)\n  • Enviar mensajes de prueba al grupo o a un chat privado\n  • Consultar info del grupo\n  • Ver si el webhook está registrado (y limpiarlo si es necesario)\n\n⛔ NO incluye getUpdates — en modo poll el poller ya consume esa cola y dos consumidores se pisarían.",
      "item": [
        {
          "name": "GET getMe — Verificar token del bot",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{TG_BASE}}/bot{{TG_TOKEN}}/getMe",
              "host": ["{{TG_BASE}}"],
              "path": ["bot{{TG_TOKEN}}", "getMe"]
            },
            "description": "⚡ Empezar aquí. Respuesta ok=true confirma que el token es válido y el bot existe."
          }
        },
        {
          "name": "GET getChat — Info del grupo WC2026",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{TG_BASE}}/bot{{TG_TOKEN}}/getChat?chat_id={{TG_GROUP}}",
              "host": ["{{TG_BASE}}"],
              "path": ["bot{{TG_TOKEN}}", "getChat"],
              "query": [{ "key": "chat_id", "value": "{{TG_GROUP}}" }]
            },
            "description": "Confirma que el bot tiene acceso al grupo. Devuelve nombre, tipo, descripción."
          }
        },
        {
          "name": "POST sendMessage — Mensaje de prueba al grupo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chat_id\": \"{{TG_GROUP}}\",\n  \"text\": \"🧪 Test Postman — Bot activo y respondiendo\",\n  \"parse_mode\": \"HTML\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{TG_BASE}}/bot{{TG_TOKEN}}/sendMessage",
              "host": ["{{TG_BASE}}"],
              "path": ["bot{{TG_TOKEN}}", "sendMessage"]
            },
            "description": "Envía un mensaje al grupo. Útil para verificar que el bot puede escribir."
          }
        },
        {
          "name": "POST sendMessage — Mensaje de prueba privado (reemplazar chat_id)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chat_id\": \"TU_CHAT_ID_PERSONAL\",\n  \"text\": \"🧪 Test desde Postman — respuesta del motor WC2026\",\n  \"parse_mode\": \"HTML\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{TG_BASE}}/bot{{TG_TOKEN}}/sendMessage",
              "host": ["{{TG_BASE}}"],
              "path": ["bot{{TG_TOKEN}}", "sendMessage"]
            },
            "description": "Reemplazar TU_CHAT_ID_PERSONAL con tu Telegram user ID (obtenelo con @userinfobot)."
          }
        },
        {
          "name": "GET getWebhookInfo — ¿Hay webhook registrado?",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{TG_BASE}}/bot{{TG_TOKEN}}/getWebhookInfo",
              "host": ["{{TG_BASE}}"],
              "path": ["bot{{TG_TOKEN}}", "getWebhookInfo"]
            },
            "description": "En modo poll, url debería estar vacío. Si hay una URL registrada y usás poll, los updates se irán al webhook y el poller no los recibirá."
          }
        },
        {
          "name": "POST deleteWebhook — Limpiar webhook (si está registrado)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"drop_pending_updates\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{TG_BASE}}/bot{{TG_TOKEN}}/deleteWebhook",
              "host": ["{{TG_BASE}}"],
              "path": ["bot{{TG_TOKEN}}", "deleteWebhook"]
            },
            "description": "⚠️ Solo ejecutar si getWebhookInfo devuelve una URL activa. Poner drop_pending_updates=true para descartar mensajes viejos acumulados."
          }
        },
        {
          "name": "GET getChatMember — ¿El bot es admin del grupo?",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{TG_BASE}}/bot{{TG_TOKEN}}/getChatMember?chat_id={{TG_GROUP}}&user_id=8903743847",
              "host": ["{{TG_BASE}}"],
              "path": ["bot{{TG_TOKEN}}", "getChatMember"],
              "query": [
                { "key": "chat_id", "value": "{{TG_GROUP}}" },
                { "key": "user_id", "value": "8903743847", "description": "ID numérico del bot (primer segmento del token)" }
              ]
            },
            "description": "Verifica si el bot tiene permisos de administrador en el grupo. Necesario para enviar mensajes en grupos con restricciones."
          }
        }
      ]
    },

