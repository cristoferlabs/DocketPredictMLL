# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Password de Postgres (Dashboard → Project Settings → Database). Solo para scripts/apply_sql_migration.py
# SUPABASE_DB_PASSWORD=
# O conexion directa:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# LLM agente — Ollama (gratis, local, sin API de pago)
# Instalar: https://ollama.com → luego: ollama pull llama3.2
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=glm-4.7-flash:latest
# Sin Ollama disponible, usar solo respuestas template: LLM_PROVIDER=template

# Telegram Bot (canal principal — reemplaza WhatsApp)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_GROUP_ID=-1000000000000
# ID del grupo donde publicar análisis diarios (opcional)
# Ejemplo: -1004300673791
# Canal de ingesta: n8n (recomendado) | poll (solo dev local, sin n8n Telegram Trigger)
TELEGRAM_INGESTION_MODE=n8n
# n8n Cloud sin plan Variables: edita API_BASE_URL en n8n/workflows/telegram_inbound.json
# (nodo Config y Normalize). URL publica HTTPS; nunca 127.0.0.1 ni $env

# WhatsApp Meta Cloud API (legacy / opcional)
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Redis (Railway or local)
REDIS_URL=redis://localhost:6379 

# API keys — data sources (planes gratuitos)
# football-data: temporada actual | api-football free: solo 2022-2024
API_FOOTBALL_KEY=
FOOTBALL_DATA_KEY=
SPORTMONKS_KEY=
ODDS_API_KEY=
OPENWEATHER_KEY=

# App
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Worker
ARQ_MAX_JOBS=10
EVALUATION_BATCH_SIZE=100
RETRAIN_THRESHOLD=200

# EV guardrails y calidad de datos
EV_MIN_ROI_BACKTEST=0.0
EV_MAX_ECE=0.15
EV_MIN_EDGE_FAIR=0.03
EV_MAX_EDGE_FAIR=0.12
EV_MAX_FAIR=0.15
EV_MAX_MODEL_MARKET_DIVERGENCE=0.20
EV_MAX_DAILY_PICKS=5
KELLY_FRACTION=0.25
MIN_ODDS_BOOKS=3
